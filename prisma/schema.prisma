generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String     @id @default(uuid())
  username            String     @unique
  email               String     @unique
  password            String
  name                String?
  role                String     @default("USER")
  failedAttempts      Int        @default(0)
  isLocked            Boolean    @default(false)
  lockoutUntil        DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  needsPasswordChange Boolean    @default(true)
  tokenVersion        Int        @default(1)
  AuditLog            AuditLog[]
  sessions            Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Ingredient {
  id                String       @id @default(uuid())
  name              String       @unique
  // We change 'unit String' to a relation
  unitId            String?
  unit              Unit?        @relation(fields: [unitId], references: [id])
  stock             Float        @default(0)
  lowStockThreshold Float        @default(5)
  unitsPerPack      Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  recipeItems       RecipeItem[]
}

model Product {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  price       Float
  prepTime    Int          @default(5) // Preparation time in minutes
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id])
  imageUrl    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  ingredients RecipeItem[]
  orderItems  OrderItem[]
}

model RecipeItem {
  id           String     @id @default(uuid())
  productId    String
  ingredientId String
  quantity     Float
  // Added unit relation here so each recipe row can have a specific unit
  unitId       String
  unit         Unit       @relation(fields: [unitId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])
}

model StoreSettings {
  id              Int     @id @default(1)
  storeName       String  @default("Oftsy Creamery")
  logoUrl         String?
  themeColor      String  @default("#db2777")
  currency        String  @default("PKR")
  isTaxEnabled    Boolean @default(true)
  taxPercentage   Float   @default(17.0)
  
  // Receipt Typography & Logic
  receiptFont     String  @default("monospace")
  receiptFontSize String  @default("11px")
  receiptHeader   String? @default("THANK YOU FOR VISITING")
  receiptFooter   String? @default("PLEASE COME AGAIN")
  
  // System States
  autoPrint       Boolean @default(false)
  isKioskMode     Boolean @default(true)
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @default(cuid()) // Useful for professional receipts
  
  // Financials
  subtotal        Float       // Total before tax and discounts
  taxAmount       Float
  discountAmount  Float       @default(0) // The actual PKR value subtracted
  totalAmount     Float       // Final amount paid by customer
  
  // Marketing & Discounts
  couponCode      String?     // Stores the code (e.g., "EID2026") for history
  couponId        String?     // Relation to Coupon model if you want tracking
  discountType    String?     // "PERCENTAGE" or "FIXED"
  
  // Relationships
  paymentMethod   String      // "CASH", "CARD", "E-WALLET"
  status          String      @default("PENDING") // PENDING, PREPARING, READY, COLLECTED
  estimatedTime   DateTime?   // Calculated at checkout
  
  // Customer & Loyalty
  // If null, the system treats it as "Walk-in Customer"
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  
  pointsEarned    Int         @default(0) // Points generated by this specific order
  pointsRedeemed  Int         @default(0) // If customer used points to pay
  
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Unit {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., "Kilogram"
  short       String       // e.g., "kg"
  // Relations back to ingredients and recipe items
  ingredients Ingredient[]
  recipeItems RecipeItem[]
}

model Customer {
  id            String   @id @default(uuid())
  name          String
  phone         String   @unique
  email         String?
  address       String?  @default("")
  loyaltyPoints Int      @default(0) // Running balance
  orders        Order[]
  createdAt     DateTime @default(now())
}

model Coupon {
  id              String   @id @default(uuid())
  code            String   @unique // e.g., "EID2026"
  discountType    String   // "PERCENTAGE" or "FIXED"
  discountValue   Float
  minOrderAmount  Float    @default(0)
  expiryDate      DateTime
  isActive        Boolean  @default(true)
  usageLimit      Int      @default(100)
  usedCount       Int      @default(0)
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}
